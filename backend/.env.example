# ============================================
# MCPanel - Configuration Backend
# Copier ce fichier en .env et remplir les valeurs
# ============================================

# Port du serveur backend
PORT=3001

# Secret JWT (générer une clé forte : openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET_KEY

# Durée de validité du token JWT
JWT_EXPIRES_IN=24h

# Configuration SSH vers le serveur Ubuntu
SSH_HOST=127.0.0.1
SSH_PORT=22
SSH_USERNAME=minecraft
SSH_PRIVATE_KEY_PATH=
SSH_PASSWORD=

# Chemin du serveur Minecraft sur la machine distante
MC_SERVER_PATH=/home/minecraft/server

# Nom du screen/tmux session pour le serveur Minecraft
MC_SCREEN_NAME=minecraft

# Fichier JAR du serveur Minecraft
MC_JAR_FILE=server.jar

# RAM allouée au serveur Minecraft
MC_MIN_RAM=1G
MC_MAX_RAM=4G

# Frontend URL (pour CORS)
FRONTEND_URL=http://localhost:5173

# Admin par défaut (créé au premier lancement)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ChangeMeNow123!
